# 1. Fix MIME types for images (crucial for SVGs on Windows/XAMPP)
<IfModule mod_mime.c>
    AddType image/svg+xml .svg
    AddType image/svg+xml .svgz
    AddType image/png .png
    AddType image/jpeg .jpg .jpeg
    AddType image/gif .gif
</IfModule>

# 2. Prevent directory listing for security
Options -Indexes

# 3. Enable Browser Caching for images (improves loading speed)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

# 4. Handle Case Sensitivity (Optional but helpful)
# This prevents 404s if you accidentally typed Assets/ instead of assets/
<IfModule mod_speling.c>
    CheckCaseOnly On
</IfModule>